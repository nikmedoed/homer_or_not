{
  "manifest_version": 3,
  "key": "",
  "name": "Homer or Not",
  "version": "0.2.0",
  "description": "Local-first new tab with cached Homer services, configurable search, and quick links.",
  "permissions": ["storage"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "action": {
    "default_title": "Homer or Not"
  }
}
